{
    admin off
    auto_https off
}

:80 {
    root * /usr/share/caddy

    encode zstd gzip

    file_server {
        precompressed br gzip
    }

    # Astro genera páginas estáticas, NO es un SPA
    # Solo redirige 404 reales, no todas las rutas
    try_files {path} {path}/index.html

    # Cache agresivo para assets con hash de Astro
    @static {
        file
        path *.js *.css *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.webp *.avif
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Security Headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Permissions-Policy "microphone=(), usb=()"
    }
}