FROM oven/bun:1 AS base
WORKDIR /app

# Copy dependency configuration files for root and workspaces to cache layers
COPY package.json bun.lock biome.json ./
COPY packages/schema/package.json ./packages/schema/package.json
COPY web/package.json ./web/package.json

# Install dependencies using Bun workspaces caching
RUN bun install --frozen-lockfile

# Copy shared code packages and Astro workspace files
COPY packages ./packages
COPY web ./web

# Build static Astro site
WORKDIR /app/web
ENV NODE_ENV=production
RUN bun run build

# ── Production Stage ─────────────────────────────────────────
FROM caddy:alpine

# Copy built static files
COPY --from=builder /app/web/dist /usr/share/caddy

# Copy Caddy configuration (dedicated for landing page)
COPY Caddyfile.web /etc/caddy/Caddyfile
EXPOSE 80
CMD ["caddy", "run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
