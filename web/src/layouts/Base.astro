---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Zelys ERP — Facturación Electrónica y Gestión Empresarial para Ecuador',
  description = 'ERP en la nube con facturación electrónica SRI. Gestiona ventas, inventario, POS y manufactura desde una sola plataforma. Desde $15/mes. 14 días gratis.'
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/logo-blank-192x192.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Meta primarios -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://zelys.app" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
  </head>
  <body>
    <Header />
    <main style="flex: 1; position: relative; z-index: 1;">
      <slot />
    </main>
    <Footer />
  </body>
</html>
