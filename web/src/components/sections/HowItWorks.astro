---
/* HowItWorks — 4 pasos para estar operativo */
const steps = [
  {
    num: '1',
    title: 'Registra tu empresa',
    desc: 'Ingresa tu RUC, datos de empresa y elige tu subdominio. Tu espacio {tu-empresa}.zelys.app está listo al instante.',
  },
  {
    num: '2',
    title: 'Configura tu negocio',
    desc: 'Establecimientos SRI, bodegas, categorías de productos y unidades de medida — todo pre-configurado para Ecuador.',
  },
  {
    num: '3',
    title: 'Importa o crea tus datos',
    desc: 'Sube tu catálogo de productos, clientes y proveedores en Excel. O empieza de cero — el sistema te guía paso a paso.',
  },
  {
    num: '4',
    title: 'Factura desde el día 1',
    desc: 'Tu equipo emite la primera factura autorizada por el SRI en los primeros minutos. Agrega usuarios y bodegas sin límite.',
  },
];
---

<section class="section section--alt" id="how-it-works">
  <div class="container">
    <h2 class="section-title">
      Operativo en menos de 15 minutos.<br/>Sin consultor, sin migración de semanas.
    </h2>
    <p class="section-subtitle" style="margin-bottom: 4rem;">
      Cuatro pasos y tu empresa está facturando electrónicamente.
    </p>

    <div class="steps-grid">
      {steps.map((step, i) => (
        <div class="step-item">
          <div class="step-circle">{step.num}</div>
          {i < steps.length - 1 && <div class="step-connector" aria-hidden="true"></div>}
          <h3>{step.title}</h3>
          <p>{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }

  .step-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    padding: 0 1.5rem;
    position: relative;
  }

  .step-circle {
    width: 48px;
    height: 48px;
    border: 2px solid var(--accent-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--accent-primary);
    background: var(--bg-surface);
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  /* Línea punteada entre pasos */
  .step-connector {
    position: absolute;
    top: 24px;
    left: calc(50% + 30px);
    width: calc(100% - 10px);
    height: 2px;
    background-image: repeating-linear-gradient(
      to right,
      var(--border-default) 0,
      var(--border-default) 6px,
      transparent 6px,
      transparent 12px
    );
    z-index: 1;
  }

  .step-item h3 {
    font-size: 1.05rem;
    font-weight: 700;
  }

  .step-item p {
    font-size: var(--text-sm);
    line-height: 1.55;
    max-width: 240px;
  }

  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .step-connector {
      display: none;
    }

    .step-item {
      flex-direction: row;
      text-align: left;
      gap: 1.25rem;
      padding: 0;
    }

    .step-item h3, .step-item p {
      max-width: none;
    }

    .step-item > :not(.step-circle):not(.step-connector) {
      flex: 1;
    }

    /* Wrap title and desc */
    .step-item {
      display: grid;
      grid-template-columns: 48px 1fr;
      grid-template-rows: auto auto;
      gap: 0.25rem 1.25rem;
    }

    .step-circle { grid-row: span 2; align-self: start; }
  }
</style>
