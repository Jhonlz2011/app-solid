---
/* Hero — Zelys ERP: dos columnas con mockup de dashboard */
---

<section class="hero">
  <!-- Glows de fondo -->
  <div class="hero-glow hero-glow--cyan" aria-hidden="true"></div>
  <div class="hero-glow hero-glow--blue" aria-hidden="true"></div>

  <div class="hero-inner">
    <!-- Columna izquierda: texto -->
    <div class="hero-text">
      <!-- Badge SRI -->
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        <span>Certificado por el SRI · Facturación electrónica incluida</span>
      </div>

      <h1>
        El ERP que las<br/>
        <span class="hero-accent">empresas</span> en Ecuador<br/>
        llevan pidiendo.
      </h1>

      <p class="hero-subtitle">
        Factura electrónicamente, controla tu inventario multi-bodega
        y gestiona tu punto de venta — todo desde una sola plataforma.
        Sin instalaciones. Sin servidores propios.
      </p>

      <div class="hero-ctas">
        <a href="https://in.zelys.app/register" class="btn-primary btn-lg">
          Registrar mi empresa — 14 días gratis
        </a>
        <a href="#features" class="btn-secondary btn-lg">
          Ver demostración ▶
        </a>
      </div>

      <p class="hero-proof">
        <span class="stars">★★★★★</span>
        Empresas activas en Ecuador · Sin tarjeta de crédito
      </p>
    </div>

    <!-- Columna derecha: mockup dashboard -->
    <div class="hero-mockup-wrap" aria-hidden="true">
      <div class="mockup">
        <!-- Sidebar -->
        <aside class="m-sidebar">
          <div class="m-logo">
            <div class="m-logo-icon"><span>Z</span></div>
            <span class="m-logo-text">Zelys ERP</span>
          </div>
          <nav class="m-nav">
            <div class="m-nav-item active">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
              Dashboard
            </div>
            <div class="m-nav-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              Inventarios
            </div>
            <div class="m-nav-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              Facturación
            </div>
            <div class="m-nav-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
              POS
            </div>
            <div class="m-nav-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
              Clientes
            </div>
            <div class="m-nav-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
              Configuración
            </div>
          </nav>
        </aside>

        <!-- Contenido principal -->
        <div class="m-main">
          <div class="m-header">
            <span class="m-title">Panel Resumen</span>
            <span class="m-company">Empresa Aistermcon</span>
          </div>

          <!-- Métricas -->
          <div class="m-metrics">
            <div class="m-metric">
              <span class="m-metric-label">Ventas del Mes</span>
              <span class="m-metric-value mono">$12,450.80</span>
              <span class="m-metric-change positive">+12.4% vs anterior</span>
            </div>
            <div class="m-metric">
              <span class="m-metric-label">Facturas SRI</span>
              <span class="m-metric-value mono">342</span>
              <span class="m-metric-change positive">100% autorizadas</span>
            </div>
            <div class="m-metric">
              <span class="m-metric-label">Productos en Alerta</span>
              <span class="m-metric-value" style="color: var(--accent-secondary);">3 Bodegas</span>
              <span class="m-metric-change neutral">Stock seguro</span>
            </div>
          </div>

          <!-- Gráfico de barras -->
          <div class="m-chart">
            <span class="m-chart-title">Flujo de Ventas Semanal</span>
            <div class="m-bars">
              <div class="m-bar" style="height: 40%;"></div>
              <div class="m-bar" style="height: 62%;"></div>
              <div class="m-bar" style="height: 48%;"></div>
              <div class="m-bar m-bar--highlight" style="height: 85%;"></div>
              <div class="m-bar" style="height: 71%;"></div>
              <div class="m-bar" style="height: 55%;"></div>
              <div class="m-bar" style="height: 40%;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 2rem 6rem;
  }

  .hero-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(60px);
  }
  .hero-glow--cyan {
    width: 700px; height: 500px;
    top: -100px; right: -100px;
    background: radial-gradient(ellipse, rgba(0,192,232,0.07), transparent);
  }
  .hero-glow--blue {
    width: 500px; height: 600px;
    bottom: -100px; left: -120px;
    background: radial-gradient(ellipse, rgba(30,114,212,0.05), transparent);
  }

  .hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  /* Texto */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    border-radius: 99px;
    border: 1px solid var(--border-active);
    background: var(--accent-primary-dim);
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    width: fit-content;
  }

  .pulse-dot {
    width: 7px; height: 7px;
    background: var(--accent-mint);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent-mint);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--accent-mint); }
    50% { opacity: 0.5; box-shadow: 0 0 14px var(--accent-mint); }
  }

  .hero h1 {
    font-size: var(--text-5xl);
    font-weight: 800;
    line-height: 1.08;
    text-align: left;
  }

  .hero-accent {
    color: var(--accent-primary);
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 520px;
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .hero-proof {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
  .stars { color: var(--warning); letter-spacing: 1px; margin-right: 0.5rem; }

  /* ═══ Mockup ═══ */
  .hero-mockup-wrap {
    perspective: 1200px;
  }

  .mockup {
    display: flex;
    height: 420px;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
    box-shadow: var(--shadow-glow-cyan);
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--text-primary);
    text-align: left;
  }

  /* Sidebar mockup */
  .m-sidebar {
    width: 175px;
    flex-shrink: 0;
    border-right: 1px solid var(--border-subtle);
    background: var(--bg-elevated);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .m-logo { display: flex; align-items: center; gap: 0.4rem; }
  .m-logo-icon {
    width: 20px; height: 20px;
    background: var(--gradient-brand);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
  }
  .m-logo-icon span { color: #fff; font-weight: 900; font-size: 0.65rem; }
  .m-logo-text { font-weight: 700; font-size: 0.8rem; }

  .m-nav { display: flex; flex-direction: column; gap: 0.3rem; }

  .m-nav-item {
    display: flex; align-items: center; gap: 0.45rem;
    padding: 0.4rem 0.6rem; border-radius: 6px;
    color: var(--text-secondary);
    font-size: 0.72rem;
    transition: background 0.15s;
  }
  .m-nav-item svg { stroke: var(--text-muted); flex-shrink: 0; }
  .m-nav-item.active {
    background: var(--accent-primary-dim);
    color: var(--text-primary);
    font-weight: 600;
  }
  .m-nav-item.active svg { stroke: var(--accent-primary); }

  /* Main mockup */
  .m-main {
    flex: 1; padding: 1rem; display: flex; flex-direction: column; gap: 0.8rem;
    overflow: hidden; background: var(--bg-base);
  }

  .m-header {
    display: flex; justify-content: space-between; align-items: center;
  }
  .m-title { font-weight: 700; font-size: 0.95rem; }
  .m-company {
    font-size: 0.7rem; font-weight: 600;
    color: var(--accent-primary);
    background: var(--accent-primary-dim);
    padding: 0.2rem 0.55rem; border-radius: 5px;
  }

  /* Métricas */
  .m-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; }

  .m-metric {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 0.7rem;
    display: flex; flex-direction: column; gap: 0.2rem;
  }
  .m-metric-label { font-size: 0.65rem; color: var(--text-secondary); }
  .m-metric-value { font-size: 1.1rem; font-weight: 700; }
  .m-metric-change { font-size: 0.6rem; }
  .m-metric-change.positive { color: var(--accent-mint); }
  .m-metric-change.neutral { color: var(--text-secondary); }

  /* Gráfico */
  .m-chart {
    flex: 1;
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    padding: 0.7rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    min-height: 100px;
  }
  .m-chart-title { font-size: 0.7rem; font-weight: 600; }

  .m-bars {
    flex: 1; display: flex; align-items: flex-end;
    gap: 0.8rem; padding-bottom: 0.3rem; justify-content: space-around;
  }

  .m-bar {
    width: 18px;
    background: linear-gradient(to top, var(--accent-deep), var(--accent-secondary));
    border-radius: 3px;
    transition: height 0.6s ease;
  }
  .m-bar--highlight {
    background: linear-gradient(to top, var(--accent-secondary), var(--accent-primary));
    box-shadow: 0 0 12px rgba(0,192,232,0.3);
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero h1 { font-size: var(--text-4xl); }
    .mockup { height: 350px; }
    .m-sidebar { width: 150px; }
  }

  @media (max-width: 640px) {
    .hero { padding: 3rem 1.25rem 4rem; }
    .hero h1 { font-size: 2.2rem; }
    .hero-ctas { flex-direction: column; }
    .hero-ctas a { width: 100%; text-align: center; }
    .m-sidebar { display: none; }
    .mockup { height: 280px; }
  }
</style>
