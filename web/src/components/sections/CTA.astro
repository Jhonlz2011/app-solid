---
/* CTA Final — Sección de cierre con glow pulsante */
---

<section class="cta-section">
  <div class="cta-glow" aria-hidden="true"></div>

  <div class="cta-inner">
    <h2>
      Tu empresa más organizada<br/>empieza hoy.
    </h2>

    <p class="cta-subtitle">
      14 días gratis. Sin tarjeta de crédito.<br/>
      Tu subdominio {'{'} empresa {'}'}.zelys.app listo en minutos.
    </p>

    <a href="https://in.zelys.app/register" class="cta-button btn-primary">
      Registrar mi empresa gratis →
    </a>

    <p class="cta-features">
      <span>✓ Listo en 15 minutos</span>
      <span>✓ Sin instalaciones</span>
      <span>✓ Subdominio personalizado</span>
    </p>
  </div>
</section>

<style>
  .cta-section {
    padding: 8rem 2rem;
    text-align: center;
    position: relative;
    background: var(--bg-surface);
    overflow: hidden;
  }

  .cta-glow {
    position: absolute;
    width: 400px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(0, 192, 232, 0.06), transparent 70%);
    filter: blur(50px);
    pointer-events: none;
  }

  .cta-inner {
    max-width: var(--max-w-narrow);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    position: relative;
    z-index: 2;
  }

  .cta-section h2 {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.12;
  }

  .cta-subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .cta-button {
    padding: 1.1rem 3rem;
    font-size: var(--text-base);
    font-weight: 800;
    border-radius: 10px;
    animation: cta-glow-pulse 2.5s ease-in-out infinite;
  }

  @keyframes cta-glow-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(0, 192, 232, 0.35), 0 4px 20px rgba(0, 192, 232, 0.2);
    }
    50% {
      box-shadow: 0 0 40px 0 rgba(0, 192, 232, 0), 0 6px 28px rgba(0, 192, 232, 0.3);
    }
  }

  .cta-features {
    display: flex;
    gap: 2rem;
    font-size: var(--text-sm);
    color: var(--text-muted);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .cta-features span {
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .cta-section { padding: 5rem 1.25rem; }
    .cta-section h2 { font-size: var(--text-3xl); }
    .cta-features { flex-direction: column; gap: 0.5rem; }
    .cta-button { width: 100%; text-align: center; }
  }
</style>
