---
/**
 * ContactForm.astro — Enterprise contact form with Cloudflare Turnstile
 *
 * Renders as a static HTML form. Client-side JS (inline <script>) handles:
 *  1. Loading the CF Turnstile widget
 *  2. Sending the form to POST /api/contact on api.zelys.app
 *  3. Showing success/error states
 *
 * No Astro SSR required — pure static + progressive enhancement.
 */
---

<div class="contact-form-wrap" id="enterprise-contact">
  <!-- Default state: form -->
  <form id="contact-form" class="contact-form" novalidate>
    <div class="cf-row">
      <div class="cf-field">
        <label for="cf-name">Nombre y apellido *</label>
        <input id="cf-name" name="name" type="text" required placeholder="Juan Pérez" autocomplete="name" />
      </div>
      <div class="cf-field">
        <label for="cf-company">Empresa *</label>
        <input id="cf-company" name="company" type="text" required placeholder="Distribuidora ABC S.A." />
      </div>
    </div>
    <div class="cf-row">
      <div class="cf-field">
        <label for="cf-email">Correo electrónico *</label>
        <input id="cf-email" name="email" type="email" required placeholder="juan@empresa.com" autocomplete="email" />
      </div>
      <div class="cf-field">
        <label for="cf-phone">Teléfono (opcional)</label>
        <input id="cf-phone" name="phone" type="tel" placeholder="+593 99 999 9999" autocomplete="tel" />
      </div>
    </div>
    <div class="cf-field">
      <label for="cf-message">¿Qué necesita tu empresa? *</label>
      <textarea id="cf-message" name="message" required rows="3" placeholder="Cuéntanos brevemente las necesidades de tu empresa: número de usuarios, módulos de interés, integraciones, etc."></textarea>
    </div>

    <!-- Turnstile widget container -->
    <div id="cf-turnstile" class="cf-turnstile-wrap"></div>

    <p id="cf-error" class="cf-error" style="display:none;"></p>

    <button type="submit" id="cf-submit" class="btn-primary cf-submit-btn" disabled>
      <span class="cf-submit-text">Enviar solicitud</span>
      <span class="cf-submit-spinner" style="display:none;">Enviando…</span>
    </button>
    <p class="cf-privacy">
      Al enviar, aceptas nuestra <a href="/privacy">política de privacidad</a>.
      Respondemos en menos de 24 horas hábiles.
    </p>
  </form>

  <!-- Success state -->
  <div id="contact-success" class="cf-success" style="display:none;">
    <div class="cf-success-icon">✓</div>
    <h4>¡Solicitud recibida!</h4>
    <p>Nuestro equipo se pondrá en contacto contigo en menos de 24 horas hábiles.</p>
  </div>
</div>

<script>
  // ─── Constants ───────────────────────────────────────────────────────────
  const SITE_KEY = '0x4AAAAAADisKN0OYEK9RMwL';
  const API_URL  = 'https://api.zelys.app/api/contact';

  // ─── Elements ────────────────────────────────────────────────────────────
  const form      = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const submitTxt = document.querySelector('.cf-submit-text') as HTMLElement | null;
  const submitSpn = document.querySelector('.cf-submit-spinner') as HTMLElement | null;
  const errorEl   = document.getElementById('cf-error') as HTMLElement | null;
  const successEl = document.getElementById('contact-success') as HTMLElement | null;

  if (!form || !submitBtn) throw new Error('[ContactForm] Elements not found');

  let turnstileToken: string | null = null;

  // ─── Load Turnstile script ───────────────────────────────────────────────
  function loadTurnstile() {
    if ((window as any).turnstile) { renderWidget(); return; }
    const script = document.createElement('script');
    script.src   = 'https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit';
    script.async = true;
    script.defer = true;
    script.onload = renderWidget;
    document.head.appendChild(script);
  }

  function renderWidget() {
    const container = document.getElementById('cf-turnstile');
    if (!container || !(window as any).turnstile) return;
    (window as any).turnstile.render(container, {
      sitekey: SITE_KEY,
      theme: 'dark',
      language: 'es',
      callback: (token: string) => {
        turnstileToken = token;
        if (submitBtn) submitBtn.disabled = false;
      },
      'expired-callback': () => {
        turnstileToken = null;
        if (submitBtn) submitBtn.disabled = true;
      },
      'error-callback': () => {
        turnstileToken = null;
        if (submitBtn) submitBtn.disabled = true;
      },
    });
  }

  // ─── Form submit ─────────────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!turnstileToken) {
      showError('Por favor, completa la verificación de seguridad.');
      return;
    }

    const data = new FormData(form);
    const name    = (data.get('name')    as string).trim();
    const company = (data.get('company') as string).trim();
    const email   = (data.get('email')   as string).trim();
    const phone   = (data.get('phone')   as string).trim();
    const message = (data.get('message') as string).trim();

    if (!name || !company || !email || !message) {
      showError('Por favor, completa todos los campos requeridos.');
      return;
    }

    setLoading(true);
    hideError();

    try {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, company, email, phone, message, turnstileToken }),
      });

      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        throw new Error((body as any)?.message || `Error ${res.status}`);
      }

      // Show success
      form.style.display = 'none';
      if (successEl) successEl.style.display = 'flex';
    } catch (err: any) {
      showError(err?.message || 'Error al enviar. Intenta de nuevo o escríbenos a soporte@zelys.app');
      // Reset Turnstile widget
      if ((window as any).turnstile) {
        (window as any).turnstile.reset(document.getElementById('cf-turnstile'));
      }
      turnstileToken = null;
      if (submitBtn) submitBtn.disabled = true;
    } finally {
      setLoading(false);
    }
  });

  function setLoading(loading: boolean) {
    if (!submitBtn || !submitTxt || !submitSpn) return;
    submitBtn.disabled = loading;
    submitTxt.style.display = loading ? 'none' : 'inline';
    submitSpn.style.display = loading ? 'inline' : 'none';
  }

  function showError(msg: string) {
    if (!errorEl) return;
    errorEl.textContent = msg;
    errorEl.style.display = 'block';
  }
  function hideError() {
    if (!errorEl) return;
    errorEl.style.display = 'none';
  }

  // Init on DOMContentLoaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadTurnstile);
  } else {
    loadTurnstile();
  }
</script>

<style>
  .contact-form-wrap {
    width: 100%;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cf-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .cf-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .cf-field label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.01em;
  }

  .cf-field input,
  .cf-field textarea {
    background: var(--bg-base);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    padding: 0.65rem 0.9rem;
    font-size: 0.9rem;
    color: var(--text-primary);
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
    resize: vertical;
    width: 100%;
    box-sizing: border-box;
  }

  .cf-field input::placeholder,
  .cf-field textarea::placeholder {
    color: var(--text-muted);
  }

  .cf-field input:focus,
  .cf-field textarea:focus {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: 0 0 0 3px rgba(0, 192, 232, 0.12);
  }

  .cf-turnstile-wrap {
    display: flex;
    justify-content: center;
    min-height: 65px;
    margin: 0.25rem 0;
  }

  .cf-error {
    font-size: 0.82rem;
    color: var(--error);
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: var(--radius-md);
    padding: 0.65rem 0.9rem;
    margin: 0;
  }

  .cf-submit-btn {
    width: 100%;
    padding: 0.9rem;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
  }

  .cf-submit-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none !important;
  }

  .cf-privacy {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
  }
  .cf-privacy a {
    color: var(--text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ── Success state ── */
  .cf-success {
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    padding: 2rem 1rem;
  }

  .cf-success-icon {
    width: 52px;
    height: 52px;
    background: rgba(0, 232, 204, 0.12);
    border: 1px solid rgba(0, 232, 204, 0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    color: var(--success);
  }

  .cf-success h4 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .cf-success p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    max-width: 300px;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 600px) {
    .cf-row { grid-template-columns: 1fr; }
  }
</style>
