---
/* Footer — Zelys ERP */
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Col 1: Logo + descripción -->
      <div class="footer-brand">
        <div class="footer-logo">
          <div class="logo-icon">
            <span>Z</span>
          </div>
          <span class="logo-text">Zelys</span>
        </div>
        <p class="footer-desc">
          Plataforma de gestión empresarial en la nube diseñada para potenciar la facturación electrónica, inventarios y operaciones de las empresas en Ecuador.
        </p>
        <!-- Redes sociales -->
        <div class="social-links">
          <a href="https://wa.me/593999999999" aria-label="WhatsApp" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </a>
          <a href="https://linkedin.com/company/zelys" aria-label="LinkedIn" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Producto -->
      <div class="footer-col">
        <h4>Producto</h4>
        <a href="#features">Características</a>
        <a href="#pricing">Precios</a>
        <a href="#faq">Preguntas frecuentes</a>
      </div>

      <!-- Col 3: Empresa -->
      <div class="footer-col">
        <h4>Empresa</h4>
        <a href="/about">Sobre nosotros</a>
        <a href="/blog">Blog</a>
      </div>

      <!-- Col 4: Soporte -->
      <div class="footer-col">
        <h4>Soporte</h4>
        <a href="mailto:soporte@zelys.app">soporte@zelys.app</a>
        <a href="/docs">Documentación</a>
        <a href="/status">Estado del sistema</a>
      </div>
    </div>

    <!-- Línea divisoria y copyright -->
    <div class="footer-bottom">
      <span>&copy; {new Date().getFullYear()} Zelys ERP. Todos los derechos reservados.</span>
      <div class="footer-legal">
        <a href="/privacy">Política de privacidad</a>
        <span class="sep">·</span>
        <a href="/terms">Términos de uso</a>
        <span class="sep">·</span>
        <span>Hecho en Ecuador 🇪🇨</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--bg-surface);
    border-top: 1px solid var(--border-subtle);
    padding: 5rem 2rem 2.5rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  /* Brand column */
  .footer-brand { display: flex; flex-direction: column; gap: 1rem; }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo-icon {
    width: 28px;
    height: 28px;
    background: linear-gradient(135deg, var(--accent-deep) 0%, var(--accent-primary) 100%);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-icon span {
    color: #fff;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 0.95rem;
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--text-primary);
  }

  .footer-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    max-width: 300px;
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .social-links a:hover { color: var(--accent-primary); }

  /* Columnas de links */
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-col h4 {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .footer-col a {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  .footer-col a:hover { color: var(--text-primary); }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid var(--border-subtle);
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-legal a { color: var(--text-muted); }
  .footer-legal a:hover { color: var(--text-secondary); }
  .sep { opacity: 0.4; }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .footer-brand { grid-column: span 2; }
    .footer-bottom { flex-direction: column; text-align: center; }
  }

  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-brand { grid-column: span 1; }
  }
</style>
