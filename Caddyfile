{
    # Admin API off for production security
    admin off

    # Global options - Desactiva HTTPS automático porque el Proxy de Coolify maneja los certificados
    auto_https off
}
:80 {
    # Set root directory
    root * /usr/share/caddy

    # Enable Zstandard (zstd) and Gzip compression
    encode zstd gzip

    # 1. Internal request from backend fetching raw index.html template
    @raw_request {
        header X-Raw-Request "true"
    }
    handle @raw_request {
        rewrite * /index.html
        file_server
    }

    # 2. Serve static files if they physically exist
    @static_assets {
        file
    }
    handle @static_assets {
        file_server {
            precompressed br gzip
        }
    }

    # 3. Proxy SPA navigation routes to backend for dynamic tenant branding
    handle {
        reverse_proxy {$BACKEND_URL:https://api.zelys.app} {
            header_up Host {$BACKEND_HOST:api.zelys.app}
            header_up X-Original-Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    # 4. Fallback: serve local static index.html if backend is offline/error
    handle_errors {
        rewrite * /index.html
        file_server
    }

    # Cache Control for Static Assets (Vite hashed files)
    @static {
        file
        path *.js *.css *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Robust Security Headers (Blindaje contra XSS, Clickjacking y Spoofing)
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        
        # 1. HSTS (Fuerza HTTPS por 2 años, incluyendo subdominios)
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        
        # 2. Permissions Policy (Apaga hardware del cliente innecesario)
        Permissions-Policy "microphone=(), usb=(), camera=(self), geolocation=(self), payment=(self), display-capture=(self)"
        
        # 3. Content Security Policy (Asegura tus orígenes legítimos y llamadas a tu API)
        Content-Security-Policy "default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://challenges.cloudflare.com 'sha256-tbGDVlXbB0fovQsCV+K5ysLRVGSMOatYAiAFkszDr0k=' 'sha256-SktNrA3FBFwWqAi4VU23wIc0PTgBulfbvaGaBOM7kWo='; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; connect-src 'self' https://api.zelys.app http://localhost:3000 https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; manifest-src 'self' https://api.zelys.app http://localhost:3000;"
    }
}